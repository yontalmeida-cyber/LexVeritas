{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/privacidade", "destination": "/privacidade.html" },
    { "source": "/termos", "destination": "/termos.html" },
    { "source": "/confirm", "destination": "/confirm.html" },
    { "source": "/manutencao", "destination": "/manutencao.html" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/google61207025d54255fe.html", "destination": "/google61207025d54255fe.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
